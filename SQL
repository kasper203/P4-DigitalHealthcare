DROP DATABASE IF EXISTS Healthcare_app;
CREATE DATABASE Healthcare_app;
USE Healthcare_app;

CREATE TABLE Login (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    brugernavn VARCHAR(100),
    password VARCHAR(255),
    type VARCHAR(10)
);

CREATE TABLE Laegeinfo (
    id INT AUTO_INCREMENT PRIMARY KEY,
    klinikadresse VARCHAR(255),
    laege_id INT,
    navn VARCHAR(100)
);

CREATE TABLE Patientinfo (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    cpr VARCHAR(10),
    foedselsdag DATE,
    adresse VARCHAR(255),
    koen VARCHAR(20),
    blodtype VARCHAR(5),
    navn VARCHAR(100),
    laege_id INT
);

CREATE TABLE Journal (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    journalinput TEXT,
    author VARCHAR(100)
);

CREATE TABLE Testinfo (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    testresultat TEXT,
    dato DATE,
    testtype VARCHAR(100),
    author VARCHAR(100)
);
